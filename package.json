{
  "name": "claude-graph",
  "version": "0.1.0",
  "description": "Turn Claude Code session transcripts into an interactive knowledge graph of what you worked on.",
  "type": "module",
  "bin": {
    "claude-graph": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
